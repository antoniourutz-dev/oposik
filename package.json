{
  "name": "quantia",
  "description": "Quantia — frontend PWA para preparar oposiciones (Vite, React, Supabase).",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rotate:internal-auth-emails": "node scripts/rotate-internal-auth-emails.mjs",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "supabase:config:push": "npx supabase config push",
    "supabase:db:push": "npx supabase db push",
    "supabase:functions:serve": "npx supabase functions serve --env-file .env.supabase",
    "supabase:functions:deploy:login": "npx supabase functions deploy login-with-username --no-verify-jwt",
    "supabase:functions:deploy:admin-user-management": "npx supabase functions deploy admin-user-management",
    "supabase:functions:deploy:daily-push": "npx supabase functions deploy daily-push-reminders --no-verify-jwt",
    "supabase:functions:deploy:sync-practice": "npx supabase functions deploy sync-practice-session --no-verify-jwt",
    "supabase:deploy:username-auth": "npm run supabase:db:push && npm run supabase:functions:deploy:login",
    "supabase:deploy:admin-tools": "npm run supabase:db:push && npm run supabase:functions:deploy:admin-user-management",
    "supabase:deploy:push-reminders": "npm run supabase:db:push && npm run supabase:functions:deploy:daily-push",
    "supabase:deploy:sync-practice": "npm run supabase:db:push && npm run supabase:functions:deploy:sync-practice"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "2.48.1",
    "@tanstack/react-query": "^5.95.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4"
  }
}
